{
  "version": 2,

  "builds": [
    {
      "src": "Backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],

  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/Backend/server.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/Frontend/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/Frontend/index.html"
    }
  ]
}